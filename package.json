{
  "name": "react",
  "version": "0.0.0",
  "private": true,
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "react": "^18.1.0",
    "react-dom": "^18.1.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test --env=jsdom",
    "test:coverage": "react-scripts test --env=jsdom --coverage --watchAll=false",
    "eject": "react-scripts eject"
  },
  "devDependencies": {
    "react-scripts": "latest"
  },
  "jest": {
    "coverageThreshold": {
      "global": {
        "lines": 60,
        "functions": 60,
        "branches": 50,
        "statements": 60
      }
    },
    "collectCoverageFrom": [
      "src/**/*.{js,jsx}",
      "!src/index.js",
      "!src/setupTests.js"
    ]
  }
}